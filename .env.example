# Firebase (Realtime Database)
# Obtenha estes valores no console do Firebase: Project settings > Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# PeerJS (opcional; se omitido usa o servidor público 0.peerjs.com)
# VITE_PEERJS_HOST=0.peerjs.com

# ICE servers para WebRTC (opcional). Por defeito usa STUN + TURN free.
# Para TURN pago (ex.: Metered), use JSON array, ex.:
# VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:...","username":"...","credential":"..."}]
